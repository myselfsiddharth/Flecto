{
  "name": "flecto",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "version": "2.0.0",
  "description": "Flecto — semantic config watcher that reports meaningful changes in plain English",
  "license": "MIT",
  "keywords": [
    "flecto",
    "cli",
    "watcher",
    "config",
    "semantic-diff",
    "devops",
    "ci"
  ],
  "homepage": "https://github.com/myselfsiddharth/Flecto#readme",
  "bugs": {
    "url": "https://github.com/myselfsiddharth/Flecto/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myselfsiddharth/Flecto.git"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "index.js",
  "bin": {
    "flecto": "index.js"
  },
  "files": [
    "index.js",
    "src/**/*",
    "schemas/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.3.0"
  }
}
